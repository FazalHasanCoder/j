{
  "name": "Godot 4.5 Stable Codespace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "noVNC Desktop",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "geequlim.godot-tools"
      ]
    }
  },
  "postCreateCommand": "chmod +x .devcontainer/setup-godot.sh .devcontainer/start-vnc.sh && bash .devcontainer/setup-godot.sh && bash .devcontainer/start-vnc.sh",
  "postStartCommand": "bash .devcontainer/start-vnc.sh"
}
